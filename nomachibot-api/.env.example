# NomachiBot API — Environment Variables
# Copy this file to .env and fill in real values

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://nomachibot_user:CHANGE_THIS_PASSWORD@localhost:5432/nomachibot"

# ── Telegram ──────────────────────────────────────────────
BOT_TOKEN=

# ── App ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_THIS_TO_A_RANDOM_256BIT_SECRET"

# Your Mini App public URL (set after VPS + domain configured)
MINI_APP_URL="https://t.me/nomachibot/app"

# The frontend (Vercel) origin. Used for the QR code URL inside the PDF,
# invite links, and the public status page link returned after confirmation.
# IMPORTANT: this must be the React app URL (e.g. https://nomachi-bot.vercel.app),
# NOT the API host. Without this, public-status links would point to the API
# host (which returns raw JSON) instead of the React page.
FRONTEND_URL="https://nomachi-bot.vercel.app"

# Your API host (where this backend is reachable). Used as a fallback only.
PUBLIC_BASE_URL="https://yourdomain.com"

# Absolute path for file storage (selfies, PDFs)
STORAGE_PATH="./storage"

# API server port
PORT=3001
